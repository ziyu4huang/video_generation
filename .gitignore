# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environment
.venv/
venv/

# Model files (too large for git)
*.safetensors
*.bin
*.pt
*.pth
*.ckpt
*.gguf

# comfyui_data — models (too large for git)
comfyui_data/models/

# comfyui_data — generated output
comfyui_data/output/
comfyui_data/temp/

# comfyui_data — input images (user uploads)
comfyui_data/input/

# comfyui_data — runtime/generated files
comfyui_data/user/*.db
comfyui_data/user/*.db-*
comfyui_data/user/*.db.lock
comfyui_data/user/*.log
comfyui_data/user/__manager/
comfyui_data/user/default/workflows/.index.json

# comfyui_data — custom nodes (third-party cloned repos)
# Use /* so negation patterns below still work
comfyui_data/custom_nodes/*
!comfyui_data/custom_nodes/ltx-missing-node-stubs/
!comfyui_data/custom_nodes/VERSIONS.txt

# comfyui_data — runtime per-node data
comfyui_data/user/default/ComfyUI-Impact-Subpack/
comfyui_data/user/default/test.json
