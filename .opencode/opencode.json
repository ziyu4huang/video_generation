{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "default_agent": "build",
  "provider": {
    "my-zai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MY-Z.AI",
      "options": {
        "baseURL": "https://api.z.ai/api/coding/paas/v4",
        "apiKey": "{env:ZAI_API_KEY}"
      },
      "models": {
        "glm-5.1": { "name": "GLM-5.1", "limit": { "context": 200000, "output": 131072 } },
        "glm-4.7": { "name": "GLM-4.7", "limit": { "context": 200000, "output": 131072 } },
        "glm-4.5-air": { "name": "GLM-4.5-Air", "limit": { "context": 131072, "output": 16384 } },
        "glm-5v-turbo": { "name": "GLM-5V-Turbo", "limit": { "context": 131072, "output": 8192 } }
      }
    },
    "my-ds": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "My-DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com",
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "timeout": 600000,
        "setCacheKey": true
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek-V4-Pro",
          "limit": { "context": 1048576, "output": 393216 }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek-V4-Flash",
          "limit": { "context": 1048576, "output": 393216 }
        }
      }
    },
    "ds4": {
      "name": "ds4.c (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "dsv4-local"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (ds4.c local)",
          "limit": {
            "context": 100000,
            "output": 384000
          }
        }
      }
    },
    "lmstudio": {
      "name": "Qwen Local (llama.cpp)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1",
        "apiKey": "qwen-local"
      },
      "models": {
        "qwen/qwen3.6-35b-a3b": {
          "name": "Qwen 3.6 35B A3B (local)",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "google/gemma-4-26b-a4b-qat": {
          "name": "Gemma 4",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    },
    "omlx": {
      "name": "oMLX (local Apple Silicon)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:8888/v1",
        "apiKey": "abcd"
      },
      "models": {
        "Gemma-4-26B-A4B-MLX-4.7bit-vision": {
          "name": "Gemma 4 26B Vision (omlx)",
          "attachment": true,
          "tool_call": true,
          "limit": {
            "context": 200000,
            "output": 32768
          }
        },
        "Qwen3.6-27B-MTPLX-Optimized-Speed": {
          "name": "Qwen 3.6 27B Speed (omlx)",
          "reasoning": true,
          "interleaved": { "field": "reasoning_content" },
          "tool_call": true,
          "limit": {
            "context": 200000,
            "output": 32768
          }
        }
      }
    }
  },
  "agent": {
    "build-my-zai": {
      "mode": "primary",
      "model": "my-zai/glm-5.1",
      "description": "GLM main coding agent"
    },
    "plan-my-zai": {
      "mode": "primary",
      "model": "my-zai/glm-4.7",
      "description": "GLM planning and analysis",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "explore-my-zai": {
      "mode": "all",
      "model": "my-zai/glm-4.5-air",
      "description": "GLM fast codebase exploration"
    },
    "build-my-ds": {
      "mode": "all",
      "model": "my-ds/deepseek-v4-pro",
      "description": "My-DeepSeek V4 Pro coding agent"
    },
    "plan-my-ds": {
      "mode": "primary",
      "model": "my-ds/deepseek-v4-pro",
      "description": "My-DeepSeek V4 Pro planning and analysis",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "explore-my-ds": {
      "mode": "subagent",
      "model": "my-ds/deepseek-v4-flash",
      "description": "DeepSeek V4 Flash exploration"
    },
    "ds4": {
      "description": "DeepSeek V4 Flash served by local ds4-server",
      "model": "ds4/deepseek-v4-flash",
      "temperature": 0
    },
    "explore": {
      "description": "Fast codebase explorer - Searches files, answers codebase questions",
      "mode": "primary",
      "model": "my-ds/deepseek-v4-flash",
      "permission": { "edit": "deny", "bash": "allow" }
    },
    "build": {
      "description": "Full-permission build agent - edit/bash/task all allowed",
      "mode": "primary",
      "model": "my-ds/deepseek-v4-pro",
      "permission": { "edit": "allow", "bash": "allow", "task": { "*": "allow" } }
    },
    "Build_Qwen35VL": {
      "description": "Qwen 3.6 35B A3B local build agent",
      "mode": "primary",
      "model": "lmstudio/qwen/qwen3.6-35b-a3b",
      "permission": { "edit": "allow", "bash": "allow", "task": { "*": "allow" } }
    },
    "Build_Qwen27b": {
      "description": "Qwen 3.6 27B Speed local build agent (oMLX)",
      "mode": "primary",
      "model": "omlx/Qwen3.6-27B-MTPLX-Optimized-Speed",
      "permission": { "edit": "allow", "bash": "allow", "task": { "*": "allow" } }
    },
    "Build_Gemma4": {
      "description": "Gemma 4 26B Vision local build agent (oMLX)",
      "mode": "primary",
      "model": "lmstudio/google/gemma-4-26b-a4b-qat",
      "permission": { "edit": "allow", "bash": "allow", "task": { "*": "allow" } }
    },
    "plan": {
      "description": "Full-permission plan agent - edit/bash/task all allowed",
      "mode": "primary",
      "model": "my-ds/deepseek-v4-pro",
      "permission": { "edit": "allow", "bash": "allow", "task": { "*": "allow" } }
    },
    "vlm-review": {
      "description": "VLM image quality reviewer — analyzes images for character consistency, artifacts, scene accuracy using local Gemma 4 26B Vision via omlx",
      "mode": "subagent",
      "model": "omlx/Gemma-4-26B-A4B-MLX-4.7bit-vision",
      "permission": {
        "edit": "deny",
        "bash": "allow"
      }
    },
    "omlx-fast": {
      "description": "oMLX fast text-only reasoning — Qwen 3.6 27B for classification, summarization, quick analysis",
      "mode": "subagent",
      "model": "omlx/Qwen3.6-27B-MTPLX-Optimized-Speed",
      "permission": {
        "edit": "deny",
        "bash": "allow"
      }
    }
  },
  "mcp": {
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}"
      }
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}"
      }
    },
    "zread": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}"
      }
    },
    "zai-mcp-server": {
      "type": "local",
      "command": ["bunx", "-y", "@z_ai/mcp-server"],
      "environment": {
        "ZAI_API_KEY": "{env:ZAI_API_KEY}",
        "Z_AI_MODE": "ZAI"
      }
    }
  },
  "instructions": ["AGENTS.md"],
  "permission": {
    "bash": {
      "*": "ask",
      "cargo*": "allow",
      "git*": "allow"
    }
  }
}
